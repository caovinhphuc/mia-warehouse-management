  "scripts": {
    "dev": "webpack --mode development",
    "start": "react-scripts start",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "test": "react-scripts test",
    "deploy": "sh deploy.sh",
    "start-dev": "sh start-dev.sh",
    "start:prod": "react-scripts start",
    "build:prod": "GENERATE_SOURCEMAP=false webpack --mode production",
    "test-server": "node test-server.js",
    "test-apps-script": "node test-apps-script.js",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "test:watch": "react-scripts test --watch",
    "eject": "react-scripts eject",
    "lint-staged": "lint-staged",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix:check": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --check",
    "build:vercel": "GENERATE_SOURCEMAP=true npm run build",
    "deploy:vercel": "vercel --prod",
    "postinstall": "npx patch-package",
    "prepare": "patch-package",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
